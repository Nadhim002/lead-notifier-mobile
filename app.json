{
  "expo": {
    "name": "Lead Notifier",
    "slug": "lead-notifier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.leadnotifier.app",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "USE_FULL_SCREEN_INTENT",
        "VIBRATE",
        "USE_NOTIFICATION_POLICY"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "@react-native-google-signin/google-signin",
      "./plugins/withFullScreenIntent"
    ],
    "extra": {
      "eas": {
        "projectId": "5635e641-abc0-4da2-a750-40eee3c48a30"
      }
    }
  }
}
